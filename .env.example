# Environment Variables Template
# Copy to .env.local and preench com seus valores
# NUNCA commitar .env.local no Git

# ============================================
# ANALYTICS & TRACKING
# ============================================

# Google Analytics 4
# Obter em: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXXXXX

# Google Tag Manager (Optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# Hotjar (Optional)
NEXT_PUBLIC_HOTJAR_ID=
NEXT_PUBLIC_HOTJAR_VERSION=

# ============================================
# COMMUNICATION
# ============================================

# WhatsApp Business API
# Seu número com código país
NEXT_PUBLIC_WHATSAPP_PHONE=5592981065678

# Email para notificações
CONTACT_EMAIL=contato@ironwooddecor.com
SMTP_USER=
SMTP_PASSWORD=

# ============================================
# SITE CONFIGURATION
# ============================================

# URL do site (com protocolo)
NEXT_PUBLIC_SITE_URL=https://ironwooddecor.com

# Nome do site
NEXT_PUBLIC_SITE_NAME=Iron Wood Decor

# Descrição padrão
NEXT_PUBLIC_SITE_DESCRIPTION=Peças sob medida em madeira nativa para salas, varandas, áreas gourmet e ambientes que pedem presença em Manaus-AM.

# Ambiente
NODE_ENV=production

# ============================================
# DATABASE (Para futuro uso)
# ============================================

# Exemplo para Supabase, MongoDB, etc.
# DATABASE_URL=
# DATABASE_SECRET=

# ============================================
# API KEYS (Se usar backend externo)
# ============================================

# Seu API Key secreto
API_SECRET_KEY=sua-chave-super-segura-aqui

# Webhook para form submissions
FORM_WEBHOOK_URL=https://your-webhook-provider.com/webhook

# ============================================
# TERCEIROS SERVIÇOS
# ============================================

# Typeform (Optional - se usar forms externos)
NEXT_PUBLIC_TYPEFORM_ID=

# Calendly (Optional - para agendamentos)
NEXT_PUBLIC_CALENDLY_URL=

# Intercom (Optional - para live chat)
NEXT_PUBLIC_INTERCOM_ID=

# ============================================
# DEVELOPMENT (Apenas local)
# ============================================

# Debug mode
DEBUG=false

# Modo de desenvolvimento
DEV_MODE=false

# Log level (info, debug, warn, error)
LOG_LEVEL=info
